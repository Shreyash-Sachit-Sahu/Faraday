# PostgreSQL (used by Spring Boot in Phase 5)
POSTGRES_USER=faraday
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=faraday

# Qdrant
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333

# Neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=REPLACE_ME

# Spring Boot backend (JWT_SECRET = 64 random bytes base64; generate, do not commit)
JWT_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=7
CORS_ALLOWED_ORIGIN=http://localhost:3000
AUTH_MAX_FAILED=5
AUTH_LOCKOUT_MINUTES=15

# Google OAuth (Phase 5.5 — GOOGLE_CLIENT_ID from the Google console for sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI service + uploads (Phase 5.5)
# NOTE: forward slashes — Spring reads .env as a Java .properties file, where a
# backslash path like C:\...\uploads triggers "Malformed \uxxxx encoding".
AI_BASE_URL=http://127.0.0.1:8000
UPLOADS_DIR=C:/faraday-data/uploads

# Local data artifacts (kept outside OneDrive on purpose)
DATA_DIR=C:\faraday-data

# Retrieval service
RETRIEVAL_CONCURRENCY=8
RETRIEVAL_QUEUE_TIMEOUT=10
RETRIEVAL_RERANK_IN=40
RETRIEVAL_CACHE_TTL=300

# Graph RAG
GRAPH_NER_MODEL=urchade/gliner_small-v2.1
GRAPH_NER_DEVICE=cpu
GRAPH_NER_THRESHOLD=0.5
RETRIEVAL_USE_GRAPH=true

# Fine-tuning / generation
BASE_MODEL=google/gemma-2-2b-it
ADAPTER_DIR=C:\faraday-data\adapters\gemma2-faraday
GEN_MAX_NEW_TOKENS=512
GEN_TEMPERATURE=0.7
GEN_TOP_P=0.9
GEN_REPETITION_PENALTY=1.1
GEN_LOW_CONF_THRESHOLD=0.0
