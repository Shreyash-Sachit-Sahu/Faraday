# Faraday environment template.
# Copy to `.env` and fill the blanks. Non-secret defaults are filled in;
# every blank value below is a secret you set locally (.env is git-ignored).

# PostgreSQL (Spring Boot persistence)
POSTGRES_USER=faraday
# POSTGRES_PASSWORD — secret, set a strong password
POSTGRES_PASSWORD=
POSTGRES_DB=faraday

# Qdrant (vector store)
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333

# Neo4j (knowledge graph)
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
# NEO4J_PASSWORD — secret, set a strong password
NEO4J_PASSWORD=

# Spring Boot — JWT / auth
# JWT_SECRET — secret, 64 random bytes base64:
#   python -c "import secrets,base64;print(base64.b64encode(secrets.token_bytes(64)).decode())"
JWT_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=7
CORS_ALLOWED_ORIGIN=http://localhost:3000
AUTH_MAX_FAILED=5
AUTH_LOCKOUT_MINUTES=15

# Google OAuth (optional — email/password works without it)
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET — from the Google Cloud console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI service + uploads
# Use forward slashes: Spring reads .env as a Java .properties file, where a
# backslash path triggers "Malformed \uxxxx encoding".
AI_BASE_URL=http://127.0.0.1:8000
UPLOADS_DIR=C:/faraday-data/uploads
DATA_DIR=C:/faraday-data

# Retrieval service
RETRIEVAL_CONCURRENCY=8
RETRIEVAL_QUEUE_TIMEOUT=10
RETRIEVAL_RERANK_IN=40
RETRIEVAL_CACHE_TTL=300

# Graph RAG
GRAPH_NER_MODEL=urchade/gliner_small-v2.1
GRAPH_NER_DEVICE=cpu
GRAPH_NER_THRESHOLD=0.5
RETRIEVAL_USE_GRAPH=true

# Fine-tuning / generation
BASE_MODEL=google/gemma-2-2b-it
ADAPTER_DIR=C:/faraday-data/adapters/gemma2-faraday
GEN_MAX_NEW_TOKENS=1024
GEN_TEMPERATURE=0.7
GEN_TOP_P=0.9
GEN_REPETITION_PENALTY=1.1
GEN_LOW_CONF_THRESHOLD=0.0

# Generation backend — "local" (the QLoRA Gemma 2 2B; default; free) or "openai"
# (any OpenAI-compatible chat API; retrieval always stays local). Free options:
#   Groq   — GEN_REMOTE_BASE_URL=https://api.groq.com/openai/v1  (free key: console.groq.com)
#   Gemini — GEN_REMOTE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# Set GEN_REMOTE_MODEL to one the provider currently lists (e.g. a Llama-70B on Groq).
GEN_PROVIDER=local
GEN_REMOTE_BASE_URL=https://api.groq.com/openai/v1
GEN_REMOTE_MODEL=
GEN_REMOTE_API_KEY=
